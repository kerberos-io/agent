    "eject": "react-scripts eject",
    "lint": "eslint --debug 'src/**/*.{js,jsx,ts,tsx}'",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
